// Almere Pickleball Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

enum UserRole {
  MEMBER
  ORGANIZER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      UserRole @default(MEMBER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  member              Member?
  createdTournaments  Tournament[]
  createdNews         NewsArticle[]
  createdEvents       Event[]
  verifiedMatches     Match[]               @relation("MatchVerifier")
  scoreSubmissions    ScoreLog[]
  notifications       Notification[]
  addedGuestPlayers   GuestPlayer[]
  verifiedPayments    Payment[]             @relation("PaymentVerifier")

  @@index([email])
  @@map("users")
}

model Member {
  id                 String    @id @default(uuid())
  userId             String    @unique
  firstName          String
  lastName           String
  dateOfBirth        DateTime?
  phone              String?
  address            String?
  membershipType     String    @default("adult") // adult, youth, family
  membershipStart    DateTime  @default(now())
  membershipEnd      DateTime?
  duprRating         Decimal   @default(3.0) @db.Decimal(3, 1)
  skillLevel         String    @default("intermediate") // beginner, intermediate, advanced
  playPreferences    Json?     // JSON object with preferences
  profilePhotoUrl    String?

  // Relations
  user                         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  registrationsAsPlayer1       TournamentRegistration[] @relation("Player1")
  registrationsAsPlayer2       TournamentRegistration[] @relation("Player2")
  matchesAsTeam1Player1        Match[]                  @relation("Team1Player1")
  matchesAsTeam1Player2        Match[]                  @relation("Team1Player2")
  matchesAsTeam2Player1        Match[]                  @relation("Team2Player1")
  matchesAsTeam2Player2        Match[]                  @relation("Team2Player2")
  statistics                   PlayerStatistics[]
  rankings                     ClubRanking[]
  payments                     Payment[]

  @@index([userId])
  @@index([duprRating])
  @@map("members")
}

// ============================================
// TOURNAMENTS & COMPETITIONS
// ============================================

enum TournamentType {
  SINGLES
  DOUBLES
  MIXED
}

enum TournamentFormat {
  ROUND_ROBIN
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  LEAGUE
  LADDER
}

enum TournamentStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Tournament {
  id                  String           @id @default(uuid())
  name                String
  type                TournamentType
  format              TournamentFormat
  status              TournamentStatus @default(DRAFT)
  startDate           DateTime
  endDate             DateTime
  location            String
  maxParticipants     Int
  minSkillLevel       String?          // beginner, intermediate, advanced
  entryFee            Decimal          @default(0) @db.Decimal(10, 2)
  registrationDeadline DateTime
  rules               Json             // { scoring, sets, points, winBy, etc }
  hasConsolation      Boolean          @default(false)
  hasBronzeMatch      Boolean          @default(false)
  description         String?          @db.Text
  qrCode              String?
  createdById         String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  // Relations
  createdBy       User                     @relation(fields: [createdById], references: [id])
  registrations   TournamentRegistration[]
  matches         Match[]
  courtAvailability CourtAvailability[]
  guestPlayers    GuestPlayer[]
  statistics      PlayerStatistics[]
  payments        Payment[]
  notifications   Notification[]

  @@index([status])
  @@index([startDate])
  @@index([createdById])
  @@map("tournaments")
}

enum RegistrationStatus {
  PENDING
  PAID
  REFUNDED
  CANCELLED
}

enum CheckInStatus {
  NOT_ARRIVED
  CHECKED_IN
}

model TournamentRegistration {
  id                String             @id @default(uuid())
  tournamentId      String
  player1Id         String
  player2Id         String?            // Nullable for singles
  registrationDate  DateTime           @default(now())
  paymentStatus     RegistrationStatus @default(PENDING)
  paymentDate       DateTime?
  checkInStatus     CheckInStatus      @default(NOT_ARRIVED)
  checkInTime       DateTime?

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player1    Member     @relation("Player1", fields: [player1Id], references: [id])
  player2    Member?    @relation("Player2", fields: [player2Id], references: [id])

  @@unique([tournamentId, player1Id, player2Id])
  @@index([tournamentId])
  @@index([player1Id])
  @@map("tournament_registrations")
}

// ============================================
// MATCHES & SCORING
// ============================================

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  DISPUTED
  CANCELLED
}

model Match {
  id                  String      @id @default(uuid())
  tournamentId        String
  roundNumber         Int
  matchNumber         Int
  roundName           String?     // round_of_16, quarterfinal, etc
  team1Player1Id      String
  team1Player2Id      String?     // Nullable for singles
  team2Player1Id      String
  team2Player2Id      String?     // Nullable for singles
  scheduledDatetime   DateTime?
  courtNumber         Int?
  status              MatchStatus @default(SCHEDULED)
  winnerTeam          Int?        // 1 or 2
  team1Confirmed      Boolean     @default(false)
  team2Confirmed      Boolean     @default(false)
  organizerVerified   Boolean     @default(false)
  verifiedById        String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  tournament    Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team1Player1  Member         @relation("Team1Player1", fields: [team1Player1Id], references: [id])
  team1Player2  Member?        @relation("Team1Player2", fields: [team1Player2Id], references: [id])
  team2Player1  Member         @relation("Team2Player1", fields: [team2Player1Id], references: [id])
  team2Player2  Member?        @relation("Team2Player2", fields: [team2Player2Id], references: [id])
  verifiedBy    User?          @relation("MatchVerifier", fields: [verifiedById], references: [id])
  sets          Set[]
  scoreLogs     ScoreLog[]
  notifications Notification[]

  @@index([tournamentId])
  @@index([status])
  @@index([scheduledDatetime])
  @@map("matches")
}

model Set {
  id          String   @id @default(uuid())
  matchId     String
  setNumber   Int
  team1Score  Int
  team2Score  Int
  winnerTeam  Int      // 1 or 2
  createdAt   DateTime @default(now())

  // Relations
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, setNumber])
  @@index([matchId])
  @@map("sets")
}

model ScoreLog {
  id            String   @id @default(uuid())
  matchId       String
  submittedById String
  teamNumber    Int      // 1 or 2
  scoreData     Json     // Complete score submission
  timestamp     DateTime @default(now())
  ipAddress     String?

  // Relations
  match       Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  submittedBy User  @relation(fields: [submittedById], references: [id])

  @@index([matchId])
  @@index([timestamp])
  @@map("score_logs")
}

// ============================================
// COURTS & SCHEDULING
// ============================================

model Court {
  id          String              @id @default(uuid())
  name        String              @unique
  isActive    Boolean             @default(true)
  notes       String?
  availability CourtAvailability[]

  @@map("courts")
}

model CourtAvailability {
  id              String   @id @default(uuid())
  courtId         String
  tournamentId    String
  availableFrom   DateTime
  availableUntil  DateTime
  isBlocked       Boolean  @default(false)

  // Relations
  court      Court      @relation(fields: [courtId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([courtId])
  @@index([tournamentId])
  @@map("court_availability")
}

// ============================================
// RANKINGS & STATISTICS
// ============================================

model PlayerStatistics {
  id                String    @id @default(uuid())
  memberId          String
  tournamentId      String?   // Null for overall stats
  matchesPlayed     Int       @default(0)
  matchesWon        Int       @default(0)
  matchesLost       Int       @default(0)
  winPercentage     Decimal   @default(0) @db.Decimal(5, 2)
  pointsFor         Int       @default(0)
  pointsAgainst     Int       @default(0)
  pointDifferential Int       @default(0)
  setsWon           Int       @default(0)
  setsLost          Int       @default(0)
  ratingChange      Decimal   @default(0) @db.Decimal(4, 2)
  periodStartDate   DateTime
  periodEndDate     DateTime?

  // Relations
  member     Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tournament Tournament? @relation(fields: [tournamentId], references: [id])

  @@index([memberId])
  @@index([tournamentId])
  @@map("player_statistics")
}

enum RankingCategory {
  SINGLES
  DOUBLES
  MIXED
}

model ClubRanking {
  id            String          @id @default(uuid())
  memberId      String
  rankPosition  Int
  rating        Decimal         @db.Decimal(3, 1)
  matchesPlayed Int
  lastMatchDate DateTime?
  asOfDate      DateTime        @default(now())
  category      RankingCategory

  // Relations
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, category, asOfDate])
  @@index([category, rankPosition])
  @@map("club_rankings")
}

// ============================================
// PAYMENTS
// ============================================

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  IDEAL
  CREDITCARD
  BANK_TRANSFER
}

model Payment {
  id            String        @id @default(uuid())
  memberId      String
  tournamentId  String
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("EUR")
  status        PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod
  transactionId String?       @unique
  paymentDate   DateTime?
  refundDate    DateTime?
  refundReason  String?
  verifiedById  String?
  createdAt     DateTime      @default(now())

  // Relations
  member     Member      @relation(fields: [memberId], references: [id])
  tournament Tournament  @relation(fields: [tournamentId], references: [id])
  verifiedBy User?       @relation("PaymentVerifier", fields: [verifiedById], references: [id])

  @@index([memberId])
  @@index([tournamentId])
  @@index([status])
  @@map("payments")
}

// ============================================
// NOTIFICATIONS
// ============================================

enum NotificationType {
  MATCH_SCHEDULED
  MATCH_STARTING
  MATCH_COMPLETED
  SCORE_CONFLICT
  TOURNAMENT_UPDATE
  PAYMENT_RECEIVED
  GENERAL
}

model Notification {
  id           String           @id @default(uuid())
  userId       String
  type         NotificationType
  title        String
  message      String           @db.Text
  relatedMatchId     String?
  relatedTournamentId String?
  isRead       Boolean          @default(false)
  sentAt       DateTime         @default(now())
  readAt       DateTime?

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  match      Match?      @relation(fields: [relatedMatchId], references: [id])
  tournament Tournament? @relation(fields: [relatedTournamentId], references: [id])

  @@index([userId, isRead])
  @@index([sentAt])
  @@map("notifications")
}

// ============================================
// GUEST PLAYERS
// ============================================

model GuestPlayer {
  id                   String   @id @default(uuid())
  tournamentId         String
  firstName            String
  lastName             String
  email                String
  phone                String?
  estimatedSkillLevel  String
  temporaryAccessToken String   @unique
  tokenExpiry          DateTime
  addedById            String
  createdAt            DateTime @default(now())

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  addedBy    User       @relation(fields: [addedById], references: [id])

  @@index([tournamentId])
  @@index([temporaryAccessToken])
  @@map("guest_players")
}

// ============================================
// WEBSITE CONTENT
// ============================================

model NewsArticle {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  content          String   @db.Text
  excerpt          String?  @db.Text
  authorId         String
  isPublished      Boolean  @default(false)
  publishedAt      DateTime?
  featuredImageUrl String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  author User @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([isPublished, publishedAt])
  @@map("news_articles")
}

enum EventType {
  TOURNAMENT
  TRAINING
  SOCIAL
  MAINTENANCE
}

model Event {
  id                   String    @id @default(uuid())
  title                String
  description          String?   @db.Text
  eventType            EventType
  startDatetime        DateTime
  endDatetime          DateTime
  location             String
  isPublic             Boolean   @default(true)
  maxParticipants      Int?
  registrationRequired Boolean   @default(false)
  createdById          String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([startDatetime])
  @@index([isPublic])
  @@map("events")
}
