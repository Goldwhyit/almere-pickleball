# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://pickleballuser:securepassword123@localhost:5432/almere_pickleball?schema=public"

# ============================================
# JWT
# ============================================
# JWT secret for access tokens (change in production!)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# JWT secret for refresh tokens
JWT_REFRESH_SECRET="your-super-secret-refresh-jwt-key-change-this-in-production"

# JWT expiration time (e.g., '15m', '1h', '7d')
JWT_EXPIRES_IN="15m"

# ============================================
# APPLICATION
# ============================================
# Node environment
NODE_ENV="development"

# Application port
PORT=3000

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# ============================================
# EMAIL (Optional)
# ============================================
# SMTP configuration for sending emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@almere-pickleball.nl"

# ============================================
# PAYMENT (Optional)
# ============================================
# Payment gateway credentials
PAYMENT_API_KEY="your-payment-api-key"
PAYMENT_SECRET="your-payment-secret"

# ============================================
# LOGGING
# ============================================
# Log level (debug, info, warn, error)
LOG_LEVEL="debug"
