# Database
DATABASE_URL="postgresql://user:password@localhost:5432/almere_pickleball?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRATION="7d"
JWT_REFRESH_SECRET="your-super-secret-refresh-jwt-key"
JWT_REFRESH_EXPIRATION="30d"

# Application
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# Redis (optional for development)
REDIS_HOST="localhost"
REDIS_PORT=6379

# Email (SendGrid)
SENDGRID_API_KEY="your-sendgrid-api-key"
FROM_EMAIL="noreply@almere-pickleball.nl"

# Payment (Mollie)
MOLLIE_API_KEY="test_your_mollie_test_key"
MOLLIE_WEBHOOK_URL="https://your-domain.com/api/payments/webhook"

# File Upload (Cloudinary)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Application URL
APP_URL="http://localhost:3000"
